{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#geo",
      "@type": "DefinedTerm",
      "name": "GEO",
      "termCode": "GEO",
      "description": "Generative Engine Optimization，生成引擎优化",
      "inDefinedTermSet": "#knowledge-base"
    },
    {
      "@id": "#seo",
      "@type": "DefinedTerm",
      "name": "SEO",
      "termCode": "SEO",
      "description": "Search Engine Optimization，搜索引擎优化",
      "inDefinedTermSet": "#knowledge-base"
    },
    {
      "@id": "#rag",
      "@type": "DefinedTerm",
      "name": "RAG",
      "termCode": "RAG",
      "description": "Retrieval-Augmented Generation，检索增强生成",
      "inDefinedTermSet": "#knowledge-base"
    },
    {
      "@id": "#knowledge-graph",
      "@type": "DefinedTerm",
      "name": "知识图谱",
      "description": "以图结构表示实体及其关系的知识库",
      "inDefinedTermSet": "#knowledge-base"
    },
    {
      "@id": "#json-ld",
      "@type": "DefinedTerm",
      "name": "JSON-LD",
      "termCode": "JSON-LD",
      "description": "JavaScript Object Notation for Linked Data",
      "inDefinedTermSet": "#knowledge-base"
    },
    {
      "@id": "#schema-org",
      "@type": "DefinedTerm",
      "name": "Schema.org",
      "description": "结构化数据词汇表标准",
      "inDefinedTermSet": "#knowledge-base"
    },
    {
      "@id": "#ai-engine",
      "@type": "DefinedTerm",
      "name": "AI 生成引擎",
      "description": "基于大语言模型的 AI 问答系统，如 ChatGPT、Gemini、Perplexity",
      "inDefinedTermSet": "#knowledge-base"
    },
    {
      "@id": "#brand-exposure",
      "@type": "DefinedTerm",
      "name": "品牌曝光",
      "description": "通过 GEO 优化提升品牌在 AI 引擎中的提及和引用率",
      "inDefinedTermSet": "#knowledge-base"
    },
    {
      "@id": "#content-strategy",
      "@type": "DefinedTerm",
      "name": "内容策略",
      "description": "规划、创建和优化内容的系统性方法，同时满足 GEO 和 SEO 要求",
      "inDefinedTermSet": "#knowledge-base"
    },
    {
      "@id": "#title-optimization",
      "@type": "DefinedTerm",
      "name": "标题优化",
      "description": "为 GEO 和 SEO 双重优化选择文章标题的方法论",
      "inDefinedTermSet": "#knowledge-base"
    },
    {
      "@id": "#implementation-roadmap",
      "@type": "DefinedTerm",
      "name": "实施路线图",
      "description": "GEO + SEO 双重优化的 90 天分阶段实施计划",
      "inDefinedTermSet": "#knowledge-base"
    },
    {
      "@id": "#relationship-geo-seo",
      "@type": "Relationship",
      "subject": { "@id": "#geo" },
      "predicate": "relatedTo",
      "object": { "@id": "#seo" },
      "description": "GEO 与 SEO 互补，GEO 是 SEO 在 AI 时代的延伸"
    },
    {
      "@id": "#relationship-geo-rag",
      "@type": "Relationship",
      "subject": { "@id": "#geo" },
      "predicate": "enables",
      "object": { "@id": "#rag" },
      "description": "GEO 优化的内容提升 RAG 系统的检索质量"
    },
    {
      "@id": "#relationship-jsonld-schema",
      "@type": "Relationship",
      "subject": { "@id": "#json-ld" },
      "predicate": "implements",
      "object": { "@id": "#schema-org" },
      "description": "JSON-LD 是 Schema.org 结构化数据的序列化格式"
    },
    {
      "@id": "#relationship-geo-kg",
      "@type": "Relationship",
      "subject": { "@id": "#geo" },
      "predicate": "enables",
      "object": { "@id": "#knowledge-graph" },
      "description": "GEO 通过实体标注帮助构建知识图谱"
    },
    {
      "@id": "#relationship-ai-geo",
      "@type": "Relationship",
      "subject": { "@id": "#ai-engine" },
      "predicate": "benefitsFrom",
      "object": { "@id": "#geo" },
      "description": "AI 生成引擎从 GEO 优化中受益，提升内容检索和引用准确性"
    },
    {
      "@id": "#relationship-geo-brand",
      "@type": "Relationship",
      "subject": { "@id": "#geo" },
      "predicate": "enables",
      "object": { "@id": "#brand-exposure" },
      "description": "GEO 优化提升品牌在 AI 引擎中的曝光率和引用率"
    },
    {
      "@id": "#relationship-content-geo",
      "@type": "Relationship",
      "subject": { "@id": "#content-strategy" },
      "predicate": "partOf",
      "object": { "@id": "#geo" },
      "description": "内容策略是 GEO 优化的核心组成部分"
    },
    {
      "@id": "#relationship-content-seo",
      "@type": "Relationship",
      "subject": { "@id": "#content-strategy" },
      "predicate": "partOf",
      "object": { "@id": "#seo" },
      "description": "内容策略同时服务于 SEO 优化目标"
    },
    {
      "@id": "#relationship-title-content",
      "@type": "Relationship",
      "subject": { "@id": "#title-optimization" },
      "predicate": "partOf",
      "object": { "@id": "#content-strategy" },
      "description": "标题优化是内容策略的关键环节"
    },
    {
      "@id": "#relationship-roadmap-geo",
      "@type": "Relationship",
      "subject": { "@id": "#implementation-roadmap" },
      "predicate": "implements",
      "object": { "@id": "#geo" },
      "description": "实施路线图提供 GEO + SEO 双重优化的分阶段计划"
    }
  ]
